{
  "servers": {
    "filesystem": {
      "command": "node",
      "args": [
        "${workspaceFolder}/node_modules/@modelcontextprotocol/server-filesystem/dist/index.js",
        "."
      ]
    },
    "memory": {
      "command": "node",
      "args": ["${workspaceFolder}/node_modules/@modelcontextprotocol/server-memory/dist/index.js"]
    },
    "github": {
      "command": "node",
      "args": ["${workspaceFolder}/node_modules/@modelcontextprotocol/server-github/dist/index.js"]
    },
    "stitch": {
      "command": "npx",
      "args": ["-y", "stitch-mcp"],
      "env": {
        "STITCH_API_KEY": "${env:STITCH_API_KEY}"
      }
    },
    "@21st-dev/magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "${env:MAGIC_API_KEY}"
      }
    },
    "nano-banana": {
      "command": "npx",
      "args": ["-y", "nano-banana-mcp"],
      "env": {
        "NANO_BANANA_API_KEY": "${env:NANO_BANANA_API_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}